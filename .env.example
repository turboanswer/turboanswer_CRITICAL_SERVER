# Custom AI Configuration
# Replace these with your own AI service details

# Option 1: Use your own AI endpoint
CUSTOM_AI_ENDPOINT=https://your-ai-service.com/api/v1/chat
CUSTOM_AI_API_KEY=your-api-key-here
CUSTOM_AI_MODEL=your-model-name

# Option 2: Use simple text-to-text AI service
SIMPLE_AI_ENDPOINT=https://your-simple-ai.com/generate
SIMPLE_AI_API_KEY=your-simple-api-key

# Fallback: OpenAI (if no custom AI configured)
OPENAI_API_KEY=your-openai-key

# Weather and Location Services
WEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_API_KEY=your-openweather-api-key

# Other settings
STRIPE_SECRET_KEY=sk_test_your_stripe_key
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key